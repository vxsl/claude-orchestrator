/* ── Orchestrator Global Styles ──
 * True black background, high-contrast GitHub Dark palette.
 * Differentiation through text color only. Cursor is the only elevated element.
 */

Screen {
    background: #000000;
    color: #b1bac4;
}

/* Scope scrollbar styles to scrollable widgets only — universal * selector
   causes CSS recalculation on every OptionList option during cursor movement */
OptionList, VerticalScroll, TextArea, Screen {
    scrollbar-size: 1 1;
    scrollbar-background: transparent;
    scrollbar-color: #161b22;
    scrollbar-color-hover: #484f58;
    scrollbar-color-active: #58a6ff 60%;
    scrollbar-background-hover: transparent;
    scrollbar-background-active: transparent;
    scrollbar-corner-color: transparent;
}

/* ── OptionList: flat, cursor subtly lifted ── */
OptionList {
    scrollbar-size: 1 1;
    border: none;
    background: #000000;
}
OptionList > .option-list--option {
    background: transparent;
}
OptionList > .option-list--option-highlighted {
    background: #101010;
    text-style: none;
}
OptionList > .option-list--option-hover {
    background: #080808;
}

/* ── Inputs ── */
Input {
    border: none;
    background: #0d1117;
    padding: 0 1;
    height: 1;
}
Input:focus {
    border: none;
    background: #0d1117;
}

/* ── TextArea ── */
TextArea {
    border: round #161b22;
    background: #000000;
}
TextArea:focus {
    border: round #58a6ff 30%;
}

/* ── Select ── */
Select {
    border: round #161b22;
}
Select:focus {
    border: round #58a6ff 30%;
}
SelectOverlay {
    background: #0d1117;
    border: round #161b22;
}

/* ── App chrome ── */
Header {
    background: #000000;
}
Footer {
    background: #060809;
}

/* ── Modal scrim ── */
ModalScreen {
    background: #000000 90%;
}

/* ── Toast ── */
Toast {
    background: #0d1117;
    color: #b1bac4;
    border: round #161b22;
}
