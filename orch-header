#!/usr/bin/env bash
# orch-header — 2-line status bar for Claude sessions launched from orch
#
# Line 1: thread title (prominent)          model  ⏱ elapsed  cost
# Line 2: ORCH  workstream  status  category  │  msgs  tokens
set -euo pipefail

# ─── Mellow palette (ANSI 256) ──────────────────────────────────
C_BLUE=$'\033[38;5;109m'
C_PURPLE=$'\033[38;5;141m'
C_CYAN=$'\033[38;5;81m'
C_GREEN=$'\033[38;5;114m'
C_YELLOW=$'\033[38;5;221m'
C_RED=$'\033[38;5;167m'
C_ORANGE=$'\033[38;5;215m'
C_DIM=$'\033[38;5;244m'
C_WHITE=$'\033[38;5;252m'
C_RESET=$'\033[0m'
C_BOLD=$'\033[1m'
C_BG=$'\033[48;5;234m'

status_color() {
    case "$1" in
        in-progress)     printf '%s' "$C_CYAN";;
        queued)          printf '%s' "$C_DIM";;
        awaiting-review) printf '%s' "$C_PURPLE";;
        done)            printf '%s' "$C_GREEN";;
        blocked)         printf '%s' "$C_RED";;
        *)               printf '%s' "$C_DIM";;
    esac
}

cat_color() {
    case "$1" in
        work)     printf '%s' "$C_CYAN";;
        personal) printf '%s' "$C_PURPLE";;
        meta)     printf '%s' "$C_DIM";;
        *)        printf '%s' "$C_DIM";;
    esac
}

cost_color() {
    local cost="$1"
    # Strip $ and < prefix for comparison
    local num="${cost#\$}"
    num="${num#<}"
    if [[ "$cost" == "—" || "$cost" == "<\$0.01" ]]; then
        printf '%s' "$C_DIM"
    elif (( $(echo "$num >= 5.0" | bc -l 2>/dev/null || echo 0) )); then
        printf '%s' "$C_RED"
    elif (( $(echo "$num >= 1.0" | bc -l 2>/dev/null || echo 0) )); then
        printf '%s' "$C_ORANGE"
    elif (( $(echo "$num >= 0.10" | bc -l 2>/dev/null || echo 0) )); then
        printf '%s' "$C_YELLOW"
    else
        printf '%s' "$C_DIM"
    fi
}

format_elapsed() {
    local secs=$1
    if (( secs < 60 )); then
        printf '%ds' "$secs"
    elif (( secs < 3600 )); then
        printf '%dm%02ds' $((secs / 60)) $((secs % 60))
    else
        printf '%dh%02dm' $((secs / 3600)) $(((secs % 3600) / 60))
    fi
}

# ─── Parse arguments ────────────────────────────────────────────
WS_NAME="" WS_STATUS="" WS_CATEGORY="" WS_DESC="" SESSION_ID="" JSONL_PATH=""
INITIAL_TITLE=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --ws-name)     WS_NAME="$2"; shift 2;;
        --ws-status)   WS_STATUS="$2"; shift 2;;
        --ws-category) WS_CATEGORY="$2"; shift 2;;
        --ws-desc)     WS_DESC="$2"; shift 2;;
        --session-id)  SESSION_ID="$2"; shift 2;;
        --jsonl)       JSONL_PATH="$2"; shift 2;;
        --title)       INITIAL_TITLE="$2"; shift 2;;
        *)             shift;;
    esac
done

ORCH_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
START_TIME=$(date +%s)

# Hide cursor in this pane
printf '\033[?25l'
trap 'printf "\033[?25h"' EXIT

# ─── Render loop ────────────────────────────────────────────────
while true; do
    MSGS=0 TOKENS="—" COST="—" MODEL="—" TITLE=""

    if [[ -f "$JSONL_PATH" ]]; then
        # Fetch stats + session title in one Python call
        read -r MSGS TOKENS COST MODEL < <(python3 -c "
import sys
sys.path.insert(0, '$ORCH_DIR')
from sessions import parse_session
from pathlib import Path
s = parse_session(Path('$JSONL_PATH'))
if s:
    print(f'{s.message_count} {s.tokens_display} {s.cost_display} {s.model_short}')
else:
    print('0 — — —')
" 2>/dev/null) || true

        # Fetch title separately (tab-delimited to handle spaces)
        TITLE=$(python3 -c "
import sys
sys.path.insert(0, '$ORCH_DIR')
from sessions import parse_session
from pathlib import Path
s = parse_session(Path('$JSONL_PATH'))
if s:
    from thread_namer import get_session_title
    t = get_session_title(s)
    if t:
        print(t)
    else:
        from threads import _extract_first_message
        msg = _extract_first_message(s)
        if msg:
            line = msg.split(chr(10))[0].strip()
            if line.startswith('#'):
                line = line.lstrip('# ')
            if len(line) > 60:
                line = line[:57] + '...'
            print(line)
" 2>/dev/null) || true
    fi

    # Fall back to initial title or workstream name
    if [[ -z "$TITLE" ]]; then
        TITLE="${INITIAL_TITLE:-$WS_NAME}"
    fi

    ELAPSED=$(format_elapsed $(($(date +%s) - START_TIME)))
    SC=$(status_color "$WS_STATUS")
    CC=$(cat_color "$WS_CATEGORY")
    CCOST=$(cost_color "$COST")
    COLS=$(tput cols 2>/dev/null || echo 120)

    # ── Line 1: thread title (prominent) + right-aligned stats ──
    L1="${C_BG} ${C_BOLD}${C_WHITE}${TITLE}${C_RESET}${C_BG}"

    # Right side: model + elapsed + cost
    R1=""
    [[ "$MODEL" != "—" ]] && R1+="${C_CYAN}${MODEL}${C_RESET}${C_BG}  "
    R1+="${C_DIM}⏱ ${ELAPSED}${C_RESET}${C_BG}"
    if [[ "$COST" != "—" ]]; then
        R1+="  ${CCOST}${COST}${C_RESET}${C_BG}"
    fi

    # ── Line 2: workstream meta + message stats ─────────────────
    L2="${C_BG} ${C_BLUE}ORCH${C_RESET}${C_BG}"
    L2+="  ${C_PURPLE}${WS_NAME}${C_RESET}${C_BG}"
    L2+="  ${SC}${WS_STATUS}${C_RESET}${C_BG}"
    L2+="  ${CC}${WS_CATEGORY}${C_RESET}${C_BG}"
    if [[ "$MSGS" -gt 0 ]]; then
        L2+="  ${C_DIM}│${C_RESET}${C_BG}"
        L2+="  ${C_DIM}${MSGS} msgs${C_RESET}${C_BG}"
        L2+="  ${C_DIM}${TOKENS}${C_RESET}${C_BG}"
    fi

    # Render both lines (L1 left, R1 right-aligned)
    # For simplicity, just append R1 after some spacing
    printf '\033[H\033[2K%s  %s\n\033[2K%s' "$L1" "$R1" "$L2"

    sleep 5
done
