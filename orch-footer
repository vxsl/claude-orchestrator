#!/usr/bin/env bash
# orch-footer — 1-line status/action bar for Claude sessions launched from orch
#
# Shows: workstream name, session ID, cwd, git branch, keybinding hints
set -euo pipefail

# ─── ANSI palette (same dark BG as header) ────────────────────
BG=$'\033[48;5;234m'
X=$'\033[22;23;24m\033[48;5;234m'  # reset attrs, keep BG
B=$'\033[38;5;109m'    # blue
P=$'\033[38;5;141m'    # purple
G=$'\033[38;5;179m'    # gold
D=$'\033[38;5;244m'    # dim
F=$'\033[38;5;239m'    # faint
RST=$'\033[0m'
EL=$'\033[K'           # erase to EOL (uses current BG)

# ─── Parse arguments ────────────────────────────────────────────
SESSION_ID="" CWD="" WS_NAME=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --session-id) SESSION_ID="$2"; shift 2;;
        --cwd)        CWD="$2"; shift 2;;
        --ws-name)    WS_NAME="$2"; shift 2;;
        # Accept and ignore legacy args
        --ws-notes)   shift 2;;
        *)            shift;;
    esac
done

SHORT_CWD="${CWD/#$HOME/~}"
SHORT_SID="${SESSION_ID:0:8}"

# Git branch (one-shot, doesn't need refresh)
GIT_BRANCH=""
if [[ -n "$CWD" && -d "$CWD/.git" ]]; then
    GIT_BRANCH=$(git -C "$CWD" branch --show-current 2>/dev/null) || true
fi

# Hide cursor
printf '\033[?25l'
trap 'printf "\033[?25h"' EXIT

# ─── Render ─────────────────────────────────────────────────────
LINE="${BG} "
LINE+="${B}${SHORT_SID}${X}"
LINE+="  ${D}${SHORT_CWD}${X}"

if [[ -n "$GIT_BRANCH" ]]; then
    LINE+="  ${P}${GIT_BRANCH}${X}"
fi

# Keybinding hints
LINE+="  ${D}│${X}"
LINE+="  ${G}C-e${X} ${D}extract${X}"
LINE+="  ${G}C-h${X} ${D}orch${X}"

LINE+=" ${EL}${RST}"

printf '\033[2K%s' "$LINE"

# Stay alive (pane dies when script exits)
exec sleep infinity
