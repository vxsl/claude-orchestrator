#!/usr/bin/env python3
"""orch-header — persistent 3-line status bar for Claude sessions.

Runs as a single long-lived Python process (no subprocess-per-tick).
Refreshes every 1s; re-parses the JSONL only when its mtime changes.
"""

import sys
import os
import time
import signal
import argparse
from pathlib import Path

# ── ANSI palette ──────────────────────────────────────────────────────────────
BG  = '\033[48;5;234m'
X   = '\033[22;23;24m' + BG   # clear bold/italic/underline, reapply bg
B   = '\033[38;5;109m'
P   = '\033[38;5;141m'
CY  = '\033[38;5;81m'
G   = '\033[38;5;114m'
Y   = '\033[38;5;221m'
R   = '\033[38;5;167m'
O   = '\033[38;5;215m'
D   = '\033[38;5;244m'
F   = '\033[38;5;239m'
M   = '\033[38;5;248m'
W   = '\033[38;5;252m'
RST = '\033[0m'
BLD = '\033[1m'
EL  = '\033[K' + RST

STATUS_COLORS = {
    'in-progress': CY, 'queued': D, 'awaiting-review': P,
    'done': G, 'blocked': R,
}
CAT_COLORS = {'work': CY, 'personal': P}


def format_elapsed(secs):
    secs = int(secs)
    if secs < 60:
        return f'{secs}s'
    elif secs < 3600:
        return f'{secs // 60}m{secs % 60:02d}s'
    else:
        return f'{secs // 3600}h{(secs % 3600) // 60:02d}m'


def tool_bar(tc, width=8):
    cats = [('mutate', O), ('bash', W), ('read', D), ('agent', P)]
    total = sum(tc.values())
    if total == 0:
        return f'{F}{"─" * width}{X}'
    parts = []
    used = 0
    for cat, color in cats:
        n = tc.get(cat, 0)
        if not n:
            continue
        chars = min(max(1, round(n / total * width)), width - used)
        if chars > 0:
            parts.append(f'{color}{"▬" * chars}{X}')
            used += chars
    if used < width:
        parts.append(f'{F}{"─" * (width - used)}{X}')
    return ''.join(parts)


def file_list(fs):
    if not fs:
        return ''
    if len(fs) <= 4:
        return f'{D}{" ".join(fs)}{X}'
    return f'{D}{" ".join(fs[:3])} +{len(fs) - 3}{X}'


def context_bar(ctx_tokens, window_size=200_000, width=6):
    if ctx_tokens <= 0:
        return '', 0
    pct = min(100.0, ctx_tokens / window_size * 100)
    filled = max(0, min(width, round(pct / 100 * width)))
    empty = width - filled
    color = R if pct >= 90 else (O if pct >= 75 else (Y if pct >= 50 else G))
    pct_str = f'{pct:.0f}%'
    bar = f'{color}{"▬" * filled}{X}{F}{"─" * empty}{X} {color}{pct_str}{X}'
    plain_len = width + 1 + len(pct_str)
    return bar, plain_len


def get_cols():
    try:
        return os.get_terminal_size().columns
    except OSError:
        return 120


def render(args, start_time, session_cache):
    cols = get_cols()
    elapsed = format_elapsed(time.time() - start_time)

    # ── Parse session (cached by mtime) ──────────────────────────────────────
    title = ''
    model = ''
    msgs = asst_msgs = 0
    tokens_str = '—'
    duration = age = ''
    files = []
    tool_counts = {}
    last_msg = last_role = ''
    ctx_tokens = 0
    ctx_window = 200_000
    sid_short = (args.session_id or '')[:8]

    jsonl_path = Path(args.jsonl) if args.jsonl else None
    if jsonl_path and jsonl_path.exists():
        try:
            mtime = jsonl_path.stat().st_mtime
            if mtime != session_cache.get('mtime'):
                from sessions import parse_session
                s = parse_session(jsonl_path)
                session_cache['mtime'] = mtime
                session_cache['session'] = s
            s = session_cache.get('session')
            if s:
                model       = s.model_short
                msgs        = s.message_count
                asst_msgs   = s.assistant_message_count
                tokens_str  = s.tokens_display
                duration    = s.duration_display
                age         = s.age
                files       = s.files_mutated or []
                tool_counts = s.tool_counts or {}
                last_msg    = s.last_user_message_text or s.last_message_text or ''
                last_role   = 'user' if s.last_user_message_text else (s.last_message_role or '')
                ctx_tokens  = s.context_tokens
                ctx_window  = s.context_window_size

                if 'title' not in session_cache:
                    from thread_namer import get_session_title
                    t = get_session_title(s)
                    if not t:
                        from threads import _extract_first_message
                        fm = _extract_first_message(s)
                        if fm:
                            line = fm.split('\n')[0].strip().lstrip('# ')
                            t = line
                    session_cache['title'] = t or ''
                title = session_cache.get('title', '')
        except Exception:
            pass

    if not title:
        title = args.title or args.ws_name or ''

    sc = STATUS_COLORS.get(args.ws_status, D)
    cc = CAT_COLORS.get(args.ws_category, D)

    # ── Line 1: title  model  ⏱ elapsed  sid ─────────────────────────────────
    r1_parts = []
    if model and model != '—':
        r1_parts.append(f'{CY}{model}{X}')
    r1_parts.append(f'{D}⏱ {elapsed}{X}')
    r1_parts.append(f'{F}{sid_short}{X}')
    r1_text = '  '.join(r1_parts)
    r1_plain = (len(model) + 2 if model and model != '—' else 0) + len(f'⏱ {elapsed}') + 2 + 8

    title_max = cols - r1_plain - 4
    display_title = (title[:title_max - 1] + '…') if len(title) > title_max > 20 else title
    gap1 = max(2, cols - len(display_title) - 1 - r1_plain - 1)
    line1 = f'{BG} {BLD}{W}{display_title}{X}{" " * gap1}{r1_text} '

    # ── Line 2: ORCH  ws  status  category  │  msgs tokens duration age ───────
    l2 = f'{BG} {B}ORCH{X}  {P}{args.ws_name}{X}  {sc}{args.ws_status}{X}  {cc}{args.ws_category}{X}'
    r2_parts = []
    if msgs > 0:
        r2_parts.append(f'{D}{msgs}↑{asst_msgs}↓{X}')
        try:
            tok = (float(tokens_str[:-1]) * 1_000_000 if tokens_str.endswith('M')
                   else float(tokens_str[:-1]) * 1_000 if tokens_str.endswith('k')
                   else float(tokens_str) if tokens_str != '—' else 0)
        except ValueError:
            tok = 0
        tc_color = O if tok >= 500_000 else (Y if tok >= 100_000 else D)
        r2_parts.append(f'{tc_color}{tokens_str}{X}')
        if duration:
            r2_parts.append(f'{D}{duration}{X}')
        if age:
            r2_parts.append(f'{M}{age}{X}')
    if r2_parts:
        l2 += f'  {D}│{X}  ' + '  '.join(r2_parts)
    line2 = f'{l2} '

    # ── Line 3: context bar  tool bar  files  │  last message snippet ─────────
    cbar, cbar_plain = context_bar(ctx_tokens, ctx_window)
    bar = tool_bar(tool_counts)
    flist = file_list(files)

    l3 = f'{BG} '
    l3_plain = 1
    if cbar:
        l3 += f'{cbar}  '
        l3_plain += cbar_plain + 2
    l3 += bar
    l3_plain += 8
    if flist:
        l3 += f'  {flist}'
        fl_plain = (sum(len(f) for f in files[:3]) + 2 + len(str(len(files) - 3)) + 1
                    if len(files) > 4
                    else sum(len(f) for f in files[:4]) + min(len(files), 4) - 1)
        l3_plain += 2 + fl_plain

    if last_msg:
        prefix = 'you: ' if last_role == 'user' else ''
        clean = last_msg.replace('\n', ' ').strip()
        max_snip = cols - l3_plain - 8
        if max_snip > 20:
            if len(prefix + clean) > max_snip:
                clean = clean[:max_snip - len(prefix) - 1] + '…'
            snippet = f'{M}{prefix}{X}{F}{clean}{X}' if prefix else f'{F}{clean}{X}'
            l3 += f'  {D}│{X}  {snippet}'
    l3 += ' '
    line3 = l3

    sys.stdout.write(
        f'\033[H\033[2K{line1}{EL}\n'
        f'\033[2K{line2}{EL}\n'
        f'\033[2K{line3}{EL}'
    )
    sys.stdout.flush()


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument('--ws-name',     default='')
    parser.add_argument('--ws-status',   default='')
    parser.add_argument('--ws-category', default='')
    parser.add_argument('--ws-desc',     default='')
    parser.add_argument('--session-id',  default='')
    parser.add_argument('--jsonl',       default='')
    parser.add_argument('--title',       default='')
    args = parser.parse_args()

    orch_dir = Path(__file__).resolve().parent
    sys.path.insert(0, str(orch_dir))

    start_time = time.time()
    session_cache: dict = {}
    needs_render = [True]

    # Hide cursor
    sys.stdout.write('\033[?25l')
    sys.stdout.flush()

    def cleanup(*_):
        sys.stdout.write('\033[?25h\033[0m\n')
        sys.stdout.flush()
        sys.exit(0)

    def on_resize(*_):
        needs_render[0] = True

    signal.signal(signal.SIGTERM, cleanup)
    signal.signal(signal.SIGINT, cleanup)
    signal.signal(signal.SIGWINCH, on_resize)

    try:
        while True:
            try:
                render(args, start_time, session_cache)
            except Exception:
                pass
            needs_render[0] = False
            # Sleep in 0.1s chunks so resize re-renders immediately
            for _ in range(10):   # 1s total
                time.sleep(0.1)
                if needs_render[0]:
                    break
    except (KeyboardInterrupt, SystemExit):
        pass
    finally:
        sys.stdout.write('\033[?25h\033[0m\n')
        sys.stdout.flush()


if __name__ == '__main__':
    main()
