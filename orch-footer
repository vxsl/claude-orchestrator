#!/usr/bin/env bash
# orch-footer — 1-line action bar for Claude sessions launched from orch
#
# Shows: session ID, working dir, action hints
set -euo pipefail

# ─── Mellow palette ─────────────────────────────────────────────
C_BLUE=$'\033[38;5;109m'
C_GOLD=$'\033[38;5;179m'
C_DIM=$'\033[38;5;244m'
C_RESET=$'\033[0m'
C_BG=$'\033[48;5;234m'

# ─── Parse arguments ────────────────────────────────────────────
SESSION_ID="" CWD=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --session-id) SESSION_ID="$2"; shift 2;;
        --cwd)        CWD="$2"; shift 2;;
        # Accept and ignore legacy args
        --ws-notes)   shift 2;;
        *)            shift;;
    esac
done

# Abbreviate CWD
SHORT_CWD="${CWD/#$HOME/~}"

# Session ID prefix
SHORT_SID="${SESSION_ID:0:8}"

# Hide cursor
printf '\033[?25l'
trap 'printf "\033[?25h"' EXIT

# ─── Render ─────────────────────────────────────────────────────
LINE="${C_BG}"
LINE+=" ${C_BLUE}${SHORT_SID}${C_RESET}${C_BG}"
LINE+="  ${C_DIM}${SHORT_CWD}${C_RESET}${C_BG}"

# Action bar
LINE+="  ${C_DIM}│${C_RESET}${C_BG}"
LINE+="  ${C_GOLD}C-e${C_RESET}${C_BG} ${C_DIM}extract todo${C_RESET}${C_BG}"
LINE+="  ${C_DIM}C-h${C_RESET}${C_BG} ${C_DIM}orch${C_RESET}${C_BG}"
LINE+="  ${C_DIM}C-\\\\${C_RESET}${C_BG} ${C_DIM}last window${C_RESET}${C_BG}"

printf '\033[2K%s' "$LINE"

# Stay alive (pane dies when script exits)
exec sleep infinity
