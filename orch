#!/bin/bash
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"
# --no-rehash: do NOT run `pyenv rehash` on every launch. orch installs no
# Python executables, so a rehash is pointless here — and a stale rehash lock
# (~/.pyenv/shims/.pyenv-shim, left behind when a rehash is hard-killed) makes
# the default `pyenv init -` block for PYENV_REHASH_TIMEOUT (60s) and print
# "pyenv: cannot rehash: couldn't acquire lock" before the TUI ever renders.
eval "$(pyenv init - --no-rehash)"
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"

# C-j/C-k passthrough is handled in tmux.conf via session-name detection.
# C-h: from Claude session windows jumps back to orch TUI (window 0);
# on window 0, passes through so the TUI can use it.
if [ -n "$TMUX" ]; then
    tmux bind -n C-h if-shell '[ "#{window_index}" = "0" ]' 'send-keys C-h' 'select-window -t orch:0' 2>/dev/null
    # Disable tmux prefix in the orch session so ctrl+b passes through to the TUI
    tmux set-option prefix None 2>/dev/null || true

    # Distinguish Ctrl-Shift from Ctrl so C-S-j/C-S-k are bindable. Needs a
    # terminal that speaks the kitty/CSI-u keyboard protocol (Alacritty >=0.13,
    # foot, kitty, recent xterm); harmless on terminals that don't. tmux only
    # forwards extended keys to inner apps that request them, so the TUI and
    # Claude itself are unaffected.
    tmux set -s extended-keys on 2>/dev/null || true
    tmux set -as terminal-features '*:extkeys' 2>/dev/null || true

    # C-S-j / C-S-k: switch among the live session windows of the current
    # workstream, newest-first (same order as the session panel). The guard
    # makes them no-ops (passthrough) outside orch session windows.
    tmux bind -n C-S-j if-shell -F '#{@orch_ws_id}' \
        "run-shell '$SCRIPT_DIR/orch-switch-session next'" \
        'send-keys C-S-j' 2>/dev/null
    tmux bind -n C-S-k if-shell -F '#{@orch_ws_id}' \
        "run-shell '$SCRIPT_DIR/orch-switch-session prev'" \
        'send-keys C-S-k' 2>/dev/null
fi

export TEXTUAL_COLOR_SYSTEM=truecolor
export TEXTUAL_ESCAPE_DELAY=0.02
ORCH_CRASH_LOG=$(mktemp /tmp/orch-crash-XXXXXX.log)
export ORCH_CRASH_LOG
python3 "$SCRIPT_DIR/orch.py" "$@"
EXIT_CODE=$?
if [ $EXIT_CODE -ne 0 ]; then
    # Textual renders the crash inside the alt-screen buffer which is lost on exit.
    # Switch back to the normal screen, then show our saved traceback.
    tput rmcup 2>/dev/null || true
    stty sane 2>/dev/null || true
    if [ -s "$ORCH_CRASH_LOG" ]; then
        cat "$ORCH_CRASH_LOG"
    else
        echo "orch exited with code $EXIT_CODE (no traceback captured)"
    fi
    echo ""
    echo "Press Enter to close."
    read -r
fi
rm -f "$ORCH_CRASH_LOG"
