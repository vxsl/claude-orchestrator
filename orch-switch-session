#!/usr/bin/env bash
# orch-switch-session — cycle to the next/previous live Claude session window
# belonging to the SAME workstream as the current window.
#
# Order matches the orch session panel: most-recent-first, by the session
# JSONL's mtime (a faithful proxy for last_activity). Only sessions that
# currently have a live tmux window participate — you can't switch to a
# session that isn't running.
#
# Usage: orch-switch-session <next|prev> [window_id] [session_name]
#   next  -> move DOWN the panel (toward older sessions)   [C-S-j]
#   prev  -> move UP the panel   (toward newer sessions)   [C-S-k]
#
# No-op outside orch session windows, or when the workstream has <2 live
# windows. Window/session args are optional; if omitted they are resolved
# from the current client.
set -uo pipefail

dir="${1:-next}"
cur_win="${2:-$(tmux display-message -p '#{window_id}' 2>/dev/null)}"
sess="${3:-$(tmux display-message -p '#{session_name}' 2>/dev/null)}"

[ -n "$cur_win" ] || exit 0

ws_id=$(tmux display-message -t "$cur_win" -p '#{@orch_ws_id}' 2>/dev/null) || exit 0
[ -n "$ws_id" ] || exit 0   # not an orch session window — nothing to switch

# Build the ring: live windows of this workstream, recency-sorted (newest
# first), deduped to one window per session. Fields are '|'-delimited
# (ws.id is an 8-char hex slug and never contains '|').
ring=$(
    tmux list-windows -t "$sess" \
        -F '#{@orch_ws_id}|#{window_id}|#{@orch_session_id}|#{@orch_jsonl}' \
        2>/dev/null \
    | awk -F'|' -v ws="$ws_id" '$1==ws && $2!="" && $3!=""' \
    | while IFS='|' read -r _ win sid jsonl; do
          mt=0
          if [ -n "$jsonl" ] && [ -f "$jsonl" ]; then
              mt=$(stat -c %Y "$jsonl" 2>/dev/null || echo 0)
          fi
          printf '%s\t%s\t%s\n' "$mt" "$win" "$sid"
      done \
    | sort -t$'\t' -k1,1nr -k2,2 \
    | awk -F'\t' '!seen[$3]++ {print $2}'
)

mapfile -t order < <(printf '%s\n' "$ring" | awk 'NF')
n=${#order[@]}
[ "$n" -gt 1 ] || exit 0   # only one live session for this workstream

cur=-1
for i in "${!order[@]}"; do
    [ "${order[$i]}" = "$cur_win" ] && { cur=$i; break; }
done
[ "$cur" -ge 0 ] || exit 0

if [ "$dir" = "prev" ]; then
    tgt=$(( (cur - 1 + n) % n ))
else
    tgt=$(( (cur + 1) % n ))
fi

tmux select-window -t "${order[$tgt]}"
