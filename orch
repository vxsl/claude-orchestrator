#!/bin/bash
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init -)"
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"

# C-j/C-k passthrough is handled in tmux.conf via session-name detection.
# C-h: from Claude session windows jumps back to orch TUI (window 0);
# on window 0, passes through so the TUI can use it.
if [ -n "$TMUX" ]; then
    tmux bind -n C-h if-shell '[ "#{window_index}" = "0" ]' 'send-keys C-h' 'select-window -t orch:0' 2>/dev/null
    # Disable tmux prefix in the orch session so ctrl+b passes through to the TUI
    tmux set-option prefix None 2>/dev/null || true
fi

export TEXTUAL_COLOR_SYSTEM=truecolor
python3 "$SCRIPT_DIR/orch.py" "$@"
EXIT_CODE=$?
if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "orch exited with code $EXIT_CODE. Press Enter to close."
    read -r
fi
